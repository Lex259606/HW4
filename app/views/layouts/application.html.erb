<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/places">Travel Journal</a>
        
        <div class="navbar-nav ms-auto align-items-center">
          <% if session[:user_id] %>
            <% user = User.find_by({ "id" => session[:user_id] }) %>
            <span class="nav-link text-light me-3 small">
              Logged in as: <strong><%= user["first_name"] %></strong>
            </span>
            <a class="btn btn-outline-light btn-sm" href="/logout">Logout</a>
          <% else %>
            <a class="nav-link" href="/login">Login</a>
            <a class="nav-link btn btn-primary btn-sm text-white ms-2 px-3" href="/users/new">Signup</a>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container pb-5">
      <% if flash["notice"] %>
        <div class="alert alert-primary alert-dismissible fade show shadow-sm" role="alert">
          <%= flash["notice"] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
