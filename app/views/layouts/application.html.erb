<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal | The Lifestyle Collective</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
      :root {
        --tig-black: #1a1a1a;
        --tig-gold: #c5a059; /* Subtle gold accent */
        --tig-bg: #fafafa;
      }

      body {
        font-family: 'Lato', sans-serif;
        background-color: var(--tig-bg);
        color: var(--tig-black);
        -webkit-font-smoothing: antialiased;
      }

      /* Serif Headers */
      h1, h2, h3, h4, .navbar-brand {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-weight: 400;
        letter-spacing: 0.5px;
      }

      /* Minimalist Navbar */
      .navbar {
        background-color: white !important;
        border-bottom: 1px solid #eaeaea;
        padding: 1.5rem 0;
      }

      .navbar-brand {
        color: var(--tig-black) !important;
        font-size: 1.8rem;
        border-bottom: 2px solid var(--tig-black);
      }

      .nav-link {
        color: #666 !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 2px;
        font-weight: 700;
      }

      /* Chic Buttons */
      .btn-primary, .btn-dark {
        background-color: var(--tig-black) !important;
        border: none !important;
        border-radius: 0 !important; /* Sharp edges are more high-fashion */
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 2px;
        padding: 10px 20px;
        transition: all 0.3s ease;
      }

      .btn-primary:hover {
        background-color: #444 !important;
        letter-spacing: 3px;
      }

      .btn-outline-dark {
        border-radius: 0 !important;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 1px;
      }

      /* Cards & Images */
      .card {
        border: none !important;
        background-color: transparent !important;
      }

      .card-img-top {
        border-radius: 0 !important;
        filter: grayscale(20%) contrast(105%); /* That editorial photo look */
      }

      /* Custom Alert */
      .alert-primary {
        background-color: #f0f0f0;
        border: none;
        color: var(--tig-black);
        border-radius: 0;
        font-style: italic;
        font-family: 'Playfair Display', serif;
      }

      hr {
        opacity: 0.1;
      }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg mb-5">
      <div class="container">
        <a class="navbar-brand" href="/places">Travel Journal</a>
        
        <div class="navbar-nav ms-auto align-items-center">
          <% if session[:user_id] %>
            <% user = User.find_by({ "id" => session[:user_id] }) %>
            <span class="nav-link me-3 disabled">
              Logged in: <span class="text-dark"><%= user["first_name"] %></span>
            </span>
            <a class="btn btn-outline-dark btn-sm" href="/logout">Logout</a>
          <% else %>
            <a class="nav-link me-3" href="/login">Login</a>
            <a class="btn btn-primary text-white" href="/users/new">Join the Collective</a>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container pb-5">
      <% if flash["notice"] %>
        <div class="alert alert-primary alert-dismissible fade show mb-5" role="alert">
          <%= flash["notice"] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
