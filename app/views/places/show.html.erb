<div class="row mb-4 align-items-center">
  <div class="col-md-8">
    <h1 class="display-4 fw-bold"><%= @place["name"] %></h1>
  </div>
  <div class="col-md-4 text-md-end">
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary shadow-sm">+ New Post</a>
  </div>
</div>

<hr class="mb-5">

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm border-0">
        
        <% if entry.uploaded_image.attached? %>
          <%= image_tag entry.uploaded_image, class: "card-img-top" %>
        <% else %>
          <div class="bg-light text-center py-5 border-bottom">
            <span class="text-muted">No Photo Uploaded</span>
          </div>
        <% end %>

        <div class="card-body">
          <h5 class="card-title fw-bold"><%= entry["title"] %></h5>
          <p class="text-muted small mb-2"><%= entry["occurred_on"] %></p>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-4">
  <a href="/places" class="btn btn-link text-muted p-0">← Back to All Places</a>
</div>