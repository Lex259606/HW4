<div class="row mb-4">
  <div class="col-12">
    <h1><%= @place["name"] %></h1>
  </div>
</div>

<div class="row mb-4">
  <div class="col-12">
    <% if @current_user %>
<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4 mb-4">
      
      <div class="card h-100 shadow-sm">
        <% if entry.uploaded_image.attached? %>
          <%= image_tag entry.uploaded_image, class: "card-img-top" %>
        <% else %>
          <div class="bg-light text-center py-5 border-bottom">
            <span class="text-muted">No Photo</span>
          </div>
        <% end %>

        <div class="card-body">
          <h5 class="card-title fw-bold"><%= entry["title"] %></h5>
          <p class="text-muted small"><%= entry["occurred_on"] %></p>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>

    </div>
  <% end %>
</div>