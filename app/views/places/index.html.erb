<div class="row mb-4 align-items-center">
  <div class="col-md-8">
    <h1 class="display-4 fw-bold">Places</h1>
  </div>
  <div class="col-md-4 text-md-end">
    <a href="/places/new" class="btn btn-primary shadow-sm">+ New Place</a>
  </div>
</div>

<hr class="mb-5">

<div class="row">
  <% for place in @places %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm border-0">
        <div class="card-body p-4 text-center">
          <h3 class="card-title h5 mb-4 text-dark"><%= place["name"] %></h3>
          
          <a href="/places/<%= place["id"] %>" class="btn btn-outline-primary w-100">
            View Entries
          </a>
        </div>
      </div>
    </div>
  <% end %>
</div>