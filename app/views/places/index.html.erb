<div class="row mb-5">
  <div class="col-12">
    <div style="height: 450px; background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1500&q=80'); background-size: cover; background-position: center; filter: sepia(15%) contrast(95%); border: 1px solid #eee; position: relative;">
      <div class="h-100 d-flex align-items-center justify-content-center" style="background: rgba(0,0,0,0.1);">
        <h1 class="display-1 text-white italic" style="font-family: 'Playfair Display', serif; text-shadow: 2px 2px 10px rgba(0,0,0,0.2);">Inspired Wanderlust</h1>
      </div>
    </div>
  </div>
</div>

<div class="row mb-5 align-items-center">
  <div class="col-md-8">
    <h1 class="display-4">The Destinations</h1>
  </div>
  <div class="col-md-4 text-md-end">
    <a href="/places/new" class="btn btn-primary shadow-sm">+ Add a Destination</a>
  </div>
</div>

<hr class="mb-5" style="opacity: 0.1;">

<div class="row">
  <% if @places.any? %>
    <% for place in @places %>
      <div class="col-md-4 mb-5">
        <div class="card h-100" style="border: 1px solid #eee !important; background-color: #fff !important; transition: all 0.3s ease; border-radius: 0;">
          <div class="card-body p-5 text-center">
            
            <h3 class="h4 mb-2 text-dark">
              <%= place["name"] %> 
            </h3>
            
            <p class="text-muted small italic mb-4" style="font-family: 'Playfair Display', serif; letter-spacing: 1px;">
              <%= Entry.where({ "place_id" => place["id"] }).count %> Entries
            </p>
            
            <div class="mt-4">
              <a href="/places/<%= place["id"] %>" class="text-dark text-uppercase small fw-bold text-decoration-none border-bottom pb-1" style="letter-spacing: 2px; font-size: 0.7rem;">
                Explore &rarr;
              </a>
            </div>

          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12 text-center py-5">
      <div class="py-5">
        <h2 class="display-6 italic" style="font-family: 'Playfair Display', serif;">Welcome to your Travel Journal</h2>
        <p class="lead text-secondary mb-4">Your collection is currently empty.</p>
        <div class="mt-4">
          <a href="/places/new" class="btn btn-primary btn-lg">Begin Your Journey</a>
        </div>
      </div>
    </div>
  <% end %>
</div>

<footer class="mt-5 pt-5 pb-5 text-center border-top" style="background-color: transparent;">
  <div class="container">
    <div class="mb-4">
       <img src="https://cdn-icons-png.flaticon.com/512/201/201623.png" alt="compass" style="width: 40px; opacity: 0.3; filter: grayscale(100%);">
    </div>
    <p class="small text-uppercase mb-1" style="letter-spacing: 4px; color: #999;">The Journey is the Destination</p>
    <p class="italic text-muted" style="font-family: 'Playfair Display', serif; font-size: 1.1rem;">Live gracefully, travel often.</p>
  </div>
</footer>