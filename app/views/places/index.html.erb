<div class="row mb-5 align-items-center">
  <div class="col-md-8">
    <h1 class="display-4">The Destinations</h1>
  </div>
  <div class="col-md-4 text-md-end">
    <a href="/places/new" class="btn btn-primary">+ Add a Destination</a>
  </div>
</div>

<hr class="mb-5">

<div class="row">
  <% if @places.any? %>
    <% for place in @places %>
      <div class="col-md-4 mb-5">
        <div class="card h-100">
          <div class="card-body p-0 text-center">
            
            <h3 class="h4 mb-3 text-dark">
              <%= place["name"] %> 
              <span class="badge ms-1">
                (<%= Entry.where({ "place_id" => place["id"] }).count %>)
              </span>
            </h3>
            
            <div class="mt-4">
              <a href="/places/<%= place["id"] %>" class="text-dark text-uppercase small fw-bold text-decoration-none border-bottom pb-1" style="letter-spacing: 2px;">
                Explore Entries &rarr;
              </a>
            </div>

          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12 text-center py-5">
      <div class="py-5">
        <h2 class="display-6 italic">Welcome to your Travel Journal</h2>
        <p class="lead text-secondary mb-4">Your collection is currently empty.</p>
        <div class="mt-4">
          <a href="/places/new" class="btn btn-primary btn-lg">Begin Your Journey</a>
        </div>
      </div>
    </div>
  <% end %>
</div>