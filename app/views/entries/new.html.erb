<h1>New Entry for <%= @place["name"] %></h1>

<%= form_with model: @entry, local: true, multipart: true do |f| %>
  <%= f.hidden_field :place_id, value: params["place_id"] %>

  <div class="mb-3">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3">
    <%= f.label :occurred_on, class: "form-label" %>
    <%= f.date_field :occurred_on, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :uploaded_image, "Upload an Image", class: "form-label" %>
    <%= f.file_field :uploaded_image, class: "form-control" %>
  </div>

  <%= f.submit "Post Entry", class: "btn btn-primary" %>
  <a href="/places/<%= params["place_id"] %>" class="btn btn-link">Cancel</a>
<% end %>